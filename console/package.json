{
  "name": "jcloud-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web console for jcode Cloud Agent — self-hosted cloud coding agent.",
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --mode demo",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint:tokens": "node scripts/lint-tokens.mjs"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@tanstack/react-query": "^5.62.0",
    "jcode-ui": "0.1.1",
    "jcode-ui-core": "0.1.0",
    "jtype-board-react": "0.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}