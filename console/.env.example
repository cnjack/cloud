# --- jcode Cloud console env ---
# Copy to .env.local and adjust. All console-visible vars must be VITE_-prefixed.

# Static bearer token sent on every /api/v1/* request (matches orchestrator
# CONSOLE_TOKEN). OPTIONAL since the runtime login gate landed: leave it unset
# and the console shows a sign-in screen instead; a token entered there is
# stored in localStorage and wins over this env default. Leave blank in demo mode.
VITE_CONSOLE_TOKEN=dev-console-token

# Where the dev vite proxy forwards /api. Defaults to http://localhost:8080.
VITE_API_PROXY_TARGET=http://localhost:8080

# Demo mode: 1 = use the in-memory mock client (no network, fake SSE playback).
# Great for previewing the UI before the orchestrator is up, and for e2e without
# a cluster. Unset / 0 = talk to the real API via the proxy.
VITE_DEMO=0
