# Console nginx: static SPA + same-origin reverse proxy to the orchestrator.
# ${ORCHESTRATOR_URL} is substituted by the nginx image's envsubst entrypoint.
server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # API — includes the SSE run stream: buffering must be OFF and the read
    # timeout generous or live events stall behind nginx.
    location /api/ {
        proxy_pass ${ORCHESTRATOR_URL};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        # Pass the EDGE's X-Forwarded-Proto through (Kong terminates TLS in
        # front of us — our own $scheme is always http and would downgrade the
        # OAuth callback URL the orchestrator reconstructs). Empty when hit
        # directly with no edge, which the orchestrator treats as http.
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
    }

    # OAuth surface (login/callback/link/logout/providers) lives on the
    # orchestrator too — same reason the vite dev proxy forwards /auth.
    location /auth/ {
        proxy_pass ${ORCHESTRATOR_URL};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
    }

    # Device uplink (register/heartbeat/poll/ack) — the local jcode connector
    # reaches the orchestrator through this same edge. Long-poll holds up to
    # 30s, so the read timeout must clear that comfortably.
    location /internal/ {
        proxy_pass ${ORCHESTRATOR_URL};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $http_x_forwarded_proto;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 120s;
    }

    # SPA fallback.
    location / {
        try_files $uri /index.html;
    }
}
