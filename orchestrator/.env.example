# jcode Cloud Agent orchestrator — environment configuration (twelve-factor).
# Copy to .env and adjust. Every value here is read by internal/config.

# --- HTTP ---
# Address the API server listens on.
ADDR=:8080

# --- Auth (required) ---
# Static bearer token the console/CLI must present on /api/v1/* endpoints.
# Generate a strong random value, e.g. `openssl rand -hex 32`.
CONSOLE_TOKEN=change-me-console-token

# --- Database (required) ---
# pgx/v5 connection string. Migrations run automatically at boot.
DATABASE_URL=postgres://jcloud:jcloud@localhost:5432/jcloud?sslmode=disable

# --- Reconciler ---
# How often the control loop reconciles run state against the cluster.
RECONCILE_INTERVAL=3s
# Max runs in scheduling+running at once. Must be >=2 (PRD J3 parallelism).
# 0 = unlimited.
MAX_CONCURRENT_RUNS=4
# Reserved for future stall detection (last-event-timestamp based). 0 disables.
STALL_TIMEOUT=10m

# --- Backoff (Symphony formula; carried for future auto-retry) ---
# delay = min(BACKOFF_BASE_MS * 2^(attempt-1), BACKOFF_MAX_MS)
BACKOFF_BASE_MS=10000
BACKOFF_MAX_MS=300000

# --- Kubernetes ---
# Path to a kubeconfig. Leave empty to use in-cluster config.
KUBECONFIG=
# Namespace runner Jobs are created in.
K8S_NAMESPACE=jcloud
# Runner image (required unless DISABLE_K8S=1). Built in parallel by another agent.
RUNNER_IMAGE=ghcr.io/cnjack/jcloud-runner:latest
# Base URL of THIS orchestrator, reachable from runner pods (required unless DISABLE_K8S=1).
# In-cluster this is typically the Service DNS name.
ORCH_BASE_URL=http://orchestrator.jcloud.svc.cluster.local:8080
# Optional ServiceAccount for runner pods.
RUNNER_SERVICE_ACCOUNT=
# Job cleanup: seconds after a finished Job is deleted (TTLSecondsAfterFinished).
JOB_TTL_SECONDS=3600
# Anti-zombie timeout: Job activeDeadlineSeconds. Deadline exceeded => failed(timeout).
RUN_TIMEOUT_SECONDS=1800
# Runner container resource limits/requests.
RUNNER_CPU_LIMIT=2
RUNNER_MEMORY_LIMIT=4Gi
RUNNER_CPU_REQUEST=500m
RUNNER_MEMORY_REQUEST=1Gi

# --- Model (BYOK; passed straight to the runner in this MVP) ---
# In the MVP the model key is injected into the runner env (per PRD OUT-6, the
# control-plane LLM proxy + temp token is a later phase).
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=
# Model identity passed to the runner as MODEL_NAME, in jcode's "provider/model"
# form. The runner writes a custom_models config entry for unknown providers from
# this. Default "mock/mock-model" targets the bundled mock; set e.g.
# "openai/gpt-4o" for a real provider.
MODEL_NAME=mock/mock-model

# --- Dev escape hatch ---
# Set to 1 to run the API without a cluster (runs queue but never schedule).
# When 1, RUNNER_IMAGE and ORCH_BASE_URL are not required.
DISABLE_K8S=0

# --- Auth / OAuth (M2; docs/13-multitenant-blueprint.md §2) ---
# All auth env is OPTIONAL: with no AUTH_*_CLIENT_ID configured the system runs
# on CONSOLE_TOKEN alone (backward compatible) and /auth/providers is empty.
#
# AES-256-GCM key for encrypting stored provider tokens (base64 of 32 bytes,
# e.g. `openssl rand -base64 32`). REQUIRED once any provider is configured;
# a startup error otherwise. In the local deploy the gitea-bootstrap Job mints
# this into the gitea-orchestrator Secret.
AUTH_TOKEN_KEY=
# Where /auth/callback redirects back to after a successful login.
CONSOLE_URL=http://localhost:5173
# Session lifetime (default 30d).
SESSION_TTL=720h
# Per-provider OAuth app (repeat for GITHUB / GITLAB). A provider is enabled iff
# its CLIENT_ID is set. Dual-URL: EXTERNAL_URL is browser-reachable (authorize
# redirect); INTERNAL_URL is server-to-server (token exchange + API). GitHub and
# GitLab default EXTERNAL/INTERNAL to their public hosts when unset.
AUTH_GITEA_CLIENT_ID=
AUTH_GITEA_CLIENT_SECRET=
AUTH_GITEA_EXTERNAL_URL=http://localhost:3000
AUTH_GITEA_INTERNAL_URL=http://gitea.jcloud.svc.cluster.local:3000

# --- Gitea draft-PR integration (optional) ---
# GITEA_URL is the Gitea root for the PR API + clone/push origin. GITEA_TOKEN is
# a PAT with repo write scope, used by the control plane as the FALLBACK credential
# for legacy / service-principal (CONSOLE_TOKEN) runs that have no triggering user
# — an OAuth user's own token is preferred (M3). Both empty => draft-PR degrades
# to diff-only. The token is NEVER injected into the runner.
GITEA_URL=
GITEA_TOKEN=

# --- M3 runner contract ---
# SOURCE_BUNDLE_TTL: how long an orchestrator-generated source bundle is cached on
# disk before regeneration (GET /internal/v1/runs/{id}/source). Default 10m.
# NOTE: the orchestrator image ships the `git` CLI (see Dockerfile) — the control
# plane bare-clones repos to build source bundles and to push runner bundles.
SOURCE_BUNDLE_TTL=10m
