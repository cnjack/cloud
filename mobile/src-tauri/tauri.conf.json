{
  "$schema": "../gen/schemas/desktop-schema.json",
  "productName": "jcode",
  "version": "0.0.73",
  "identifier": "net.j-code.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "jcode",
        "width": 420,
        "height": 840
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["jcode"]
      },
      "mobile": [
        { "scheme": ["jcode"], "host": "auth" }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
